{
  "name": "@natheihei/sandbox-opensandbox",
  "version": "0.1.1",
  "description": "AI SDK Harness sandbox provider backed by OpenSandbox.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/natheihei/sandbox-opensandbox"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "source": "./src/index.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsup --tsconfig tsconfig.build.json",
    "clean": "del-cli dist *.tsbuildinfo",
    "type-check": "tsc --build",
    "test": "vitest --run",
    "prepack": "pnpm build"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "ai-sdk",
    "harness",
    "opensandbox",
    "sandbox"
  ],
  "dependencies": {
    "@ai-sdk/harness": "beta",
    "@ai-sdk/provider-utils": "beta",
    "@alibaba-group/opensandbox": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "del-cli": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
